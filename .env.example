# --- Database ---
# For local dev use a Railway/Neon hosted Postgres (Docker is optional).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/savdocrm?schema=public"

# --- Redis (queues, cache) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=4000
JWT_SECRET="change-me-in-prod"
JWT_EXPIRES_IN="7d"

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Database ---
# For local dev use a Neon free Postgres (Docker is optional).
# DATABASE_URL is the pooled connection (Vercel functions use this).
# DIRECT_URL is the unpooled connection (prisma migrate uses this).
# Locally both can be the direct URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/savdocrm?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/savdocrm?schema=public"

# --- Redis (queues, cache) ---
REDIS_URL="redis://localhost:6379"

# --- API ---
API_PORT=4000
JWT_SECRET="change-me-in-prod"
JWT_EXPIRES_IN="7d"
# Comma-separated allowed CORS origins. Leave empty in dev (reflects any origin).
# In production set to your Vercel URL, e.g. "https://savdocrm.vercel.app".
WEB_ORIGIN=""

# --- Web ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Telegram bot (optional) ---
# Leave both empty to disable. To enable: create a bot via @BotFather,
# put the token here and the bot's username (without @) below.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""

# Webhook mode (Vercel / any serverless host). Locally the bot uses
# long-polling and these can stay empty. In production:
#   TELEGRAM_WEBHOOK_URL    — full https URL where Telegram should POST,
#                             e.g. https://api.savdocrm.uz/api/telegram/webhook
#   TELEGRAM_WEBHOOK_SECRET — random ~32-char string; Telegram echoes it back
#                             in X-Telegram-Bot-Api-Secret-Token, the API
#                             rejects requests that don't match.
# Set TELEGRAM_BOT_MODE=webhook to force webhook mode even outside Vercel.
TELEGRAM_WEBHOOK_URL=""
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_BOT_MODE=""
